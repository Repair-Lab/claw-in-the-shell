# =============================================================================
# DBAI GhostShell OS — Umgebungsvariablen
# =============================================================================
# Kopieren und anpassen:
#   cp .env.example .env
# =============================================================================

# ─── PostgreSQL ─────────────────────────────────────────────
DBAI_DB_HOST=127.0.0.1
DBAI_DB_PORT=5432
DBAI_DB_NAME=dbai
DBAI_DB_USER=dbai_system
DBAI_DB_PASSWORD=dbai_dev_2026
DBAI_DB_RUNTIME_USER=dbai_runtime
DBAI_DB_RUNTIME_PASSWORD=dbai_runtime_2026

# ─── Web Server ─────────────────────────────────────────────
DBAI_WEB_HOST=0.0.0.0
DBAI_WEB_PORT=3000
DBAI_SECRET_KEY=dev-secret-key-change-in-production
DBAI_LOG_LEVEL=DEBUG
DBAI_ENV=development

# ─── Frontend ───────────────────────────────────────────────
DBAI_UI_PORT=5173
VITE_API_URL=http://127.0.0.1:3000

# ─── QEMU Hardware-Simulator ────────────────────────────────
# Anzahl emulierter CPU-Kerne
QEMU_CORES=4
# RAM in MB für die emulierte Hardware
QEMU_MEMORY=2048
# Anzahl virtueller Disks
QEMU_DISKS=2
# Anzahl virtueller Netzwerk-Interfaces
QEMU_NICS=1
# Injektions-Intervall in Sekunden (Daten → DB)
INJECT_INTERVAL=2.0
# Echte QEMU-VM starten (true) oder reine Software-Simulation (false)
USE_REAL_QEMU=false
# Hardware-Profil: minimal, desktop, server, stress
QEMU_PROFILE=desktop

# ─── Hardware-Simulation in Ghost-API ───────────────────────
# Wenn true, startet die API den HW-Simulator automatisch
DBAI_HW_SIMULATE=false

# ─── LLM Bridge ─────────────────────────────────────────────
# DBAI_LLM_PROVIDER=ollama
# DBAI_LLM_MODEL=llama3
# DBAI_LLM_API_URL=http://127.0.0.1:11434

# ─── Docker-Compose Overrides ───────────────────────────────
# COMPOSE_PROFILES=hw-sim        # QEMU-Simulator mit starten
# DBAI_UI_MODE=production        # Nginx statt Vite Dev Server
